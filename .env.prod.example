DEBUG=False
DJANGO_SECRET_KEY=change_me_to_a_very_secret_key
# Incluye tu dominio Fly: nombre.fly.dev y .fly.dev ya está permitido por defecto en settings.
ALLOWED_HOSTS=yikkan.com,www.yikkan.com,localhost,127.0.0.1,.fly.dev
# HTTPS en Fly / dominio propio (necesario para formularios/login con Django 4+)
CSRF_TRUSTED_ORIGINS=https://yikkan.com,https://www.yikkan.com,https://yikkan.fly.dev

# En Fly.io suele inyectarse al asociar Postgres: fly postgres attach ...
# Si está definida, tiene prioridad sobre POSTGRES_*.
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

POSTGRES_DB=uz_checkpoint
POSTGRES_USER=uz_user
POSTGRES_PASSWORD=change_me_to_strong_password
POSTGRES_HOST=db
POSTGRES_PORT=5432
